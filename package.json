{
  "name": "taller-educar",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "make": "vite build && electron-builder"
  },
  "dependencies": {
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/share": "^6.0.4",
    "electron-store": "^11.0.2",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.6"
  },
  "build": {
    "appId": "com.tallereducar.app",
    "productName": "Taller Educar",
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false
    }
  }

